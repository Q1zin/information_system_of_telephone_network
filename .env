# ---- PostgreSQL connection (req. 5: DB connection in config) ----
POSTGRES_HOST=localhost
# host port 5433 to avoid clashing with a local PostgreSQL on 5432
POSTGRES_PORT=5433
POSTGRES_DB=gts
POSTGRES_USER=gts
POSTGRES_PASSWORD=gts
# Full URL used by sqlx / SeaORM
DATABASE_URL=postgres://gts:gts@localhost:5433/gts

# Read-only role used to execute user-provided raw SQL safely (req. 6)
DATABASE_URL_READONLY=postgres://gts_ro:gts_ro@localhost:5433/gts

# ---- Application ----
APP_HOST=0.0.0.0
APP_PORT=8080
RUST_LOG=info,tower_http=debug,sqlx=warn

# Session signing/encryption key (generate a long random string)
SESSION_SECRET=change-me-to-a-very-long-random-string-at-least-64-bytes

# Bootstrap superadmin created by the backend on first run
SUPERADMIN_USERNAME=admin
SUPERADMIN_PASSWORD=admin

# ---- Frontend (Vue) ----
VITE_API_BASE_URL=http://localhost:8080/api
